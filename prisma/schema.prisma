generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  uuid                String    @unique @default(uuid())
  email               String    @unique
  firstName           String?
  lastName            String?
  lastLoggedIn        DateTime?
  createdAt           DateTime  @default(now())
  assignedTasks       Task[]    @relation("TaskAssigneeById")
  assignedTasksByUuid Task[]    @relation("TaskAssigneeByUuid")
}

model AuthUser {
  id                        Int                  @id @default(autoincrement())
  uuid                      String               @unique @default(uuid())
  email                     String               @unique
  passwordHash              String
  createdAt                 DateTime             @default(now())
  sessions                  Session[]            @relation("SessionUserById")
  sessionsByUuid            Session[]            @relation("SessionUserByUuid")
  passwordResetTokens       PasswordResetToken[] @relation("PasswordResetTokenUserById")
  passwordResetTokensByUuid PasswordResetToken[] @relation("PasswordResetTokenUserByUuid")
  createdTasks              Task[]               @relation("TaskCreatorById")
  createdTasksByUuid        Task[]               @relation("TaskCreatorByUuid")
  taskActivities            TaskActivity[]       @relation("TaskActivityUserById")
  taskActivitiesByUuid      TaskActivity[]       @relation("TaskActivityUserByUuid")
  taskComments              TaskComment[]        @relation("TaskCommentAuthorById")
  taskCommentsByUuid        TaskComment[]        @relation("TaskCommentAuthorByUuid")
  uploadedDocuments         Document[]           @relation("DocumentUploaderByUuid")
  createdDocumentFolders    DocumentFolder[]     @relation("DocumentFolderCreatorByUuid")
}

model Session {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid())
  token      String   @unique
  userId     Int
  user       AuthUser @relation("SessionUserById", fields: [userId], references: [id], onDelete: Cascade)
  userUuid   String
  userByUuid AuthUser @relation("SessionUserByUuid", fields: [userUuid], references: [uuid], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([userUuid])
}

model PasswordResetToken {
  id             Int       @id @default(autoincrement())
  uuid           String    @unique @default(uuid())
  authUserId     Int
  authUser       AuthUser  @relation("PasswordResetTokenUserById", fields: [authUserId], references: [id], onDelete: Cascade)
  authUserUuid   String
  authUserByUuid AuthUser  @relation("PasswordResetTokenUserByUuid", fields: [authUserUuid], references: [uuid], onDelete: Cascade)
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([authUserId])
  @@index([authUserUuid])
  @@index([expiresAt])
}

model Project {
  id              Int              @id @default(autoincrement())
  uuid            String           @unique @default(uuid())
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  tasks           Task[]           @relation("TaskProjectById")
  tasksByUuid     Task[]           @relation("TaskProjectByUuid")
  documentFolders DocumentFolder[] @relation("DocumentFolderProjectByUuid")

  @@index([createdAt])
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskActivityActionType {
  CREATED
  FIELD_CHANGED
}

enum TaskActivityField {
  TITLE
  DESCRIPTION
  ASSIGNEE
  DUE_DATE
  PRIORITY
  STATUS
}

model Task {
  id                      Int            @id @default(autoincrement())
  uuid                    String         @unique @default(uuid())
  title                   String
  description             String?
  assigneeId              Int?
  assignee                User?          @relation("TaskAssigneeById", fields: [assigneeId], references: [id], onDelete: SetNull)
  assigneeUuid            String?
  assigneeByUuid          User?          @relation("TaskAssigneeByUuid", fields: [assigneeUuid], references: [uuid], onDelete: SetNull)
  dueDate                 DateTime?
  priority                TaskPriority   @default(MEDIUM)
  status                  TaskStatus     @default(NOT_STARTED)
  projectId               Int?
  project                 Project?       @relation("TaskProjectById", fields: [projectId], references: [id], onDelete: SetNull)
  projectUuid             String?
  projectByUuid           Project?       @relation("TaskProjectByUuid", fields: [projectUuid], references: [uuid], onDelete: SetNull)
  createdAt               DateTime       @default(now())
  createdByAuthUserId     Int
  createdByAuthUser       AuthUser       @relation("TaskCreatorById", fields: [createdByAuthUserId], references: [id], onDelete: Restrict)
  createdByAuthUserUuid   String
  createdByAuthUserByUuid AuthUser       @relation("TaskCreatorByUuid", fields: [createdByAuthUserUuid], references: [uuid], onDelete: Restrict)
  createdByEmail          String
  activities              TaskActivity[] @relation("TaskActivityTaskById")
  activitiesByUuid        TaskActivity[] @relation("TaskActivityTaskByUuid")
  comments                TaskComment[]  @relation("TaskCommentTaskById")
  commentsByUuid          TaskComment[]  @relation("TaskCommentTaskByUuid")
  documents               Document[]     @relation("DocumentTaskByUuid")

  @@index([createdAt])
  @@index([projectId, createdAt])
  @@index([projectUuid, createdAt])
  @@index([assigneeId, createdAt])
  @@index([assigneeUuid, createdAt])
  @@index([createdByAuthUserId, createdAt])
  @@index([createdByAuthUserUuid, createdAt])
}

model TaskComment {
  id               Int      @id @default(autoincrement())
  uuid             String   @unique @default(uuid())
  taskId           Int
  task             Task     @relation("TaskCommentTaskById", fields: [taskId], references: [id], onDelete: Cascade)
  taskUuid         String
  taskByUuid       Task     @relation("TaskCommentTaskByUuid", fields: [taskUuid], references: [uuid], onDelete: Cascade)
  authorUserId     Int
  authorUser       AuthUser @relation("TaskCommentAuthorById", fields: [authorUserId], references: [id], onDelete: Restrict)
  authorUserUuid   String
  authorUserByUuid AuthUser @relation("TaskCommentAuthorByUuid", fields: [authorUserUuid], references: [uuid], onDelete: Restrict)
  body             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([taskId, createdAt])
  @@index([taskUuid, createdAt])
  @@index([authorUserId, createdAt])
  @@index([authorUserUuid, createdAt])
}

model TaskActivity {
  id         Int                    @id @default(autoincrement())
  uuid       String                 @unique @default(uuid())
  taskId     Int
  task       Task                   @relation("TaskActivityTaskById", fields: [taskId], references: [id], onDelete: Cascade)
  taskUuid   String
  taskByUuid Task                   @relation("TaskActivityTaskByUuid", fields: [taskUuid], references: [uuid], onDelete: Cascade)
  userId     Int
  user       AuthUser               @relation("TaskActivityUserById", fields: [userId], references: [id], onDelete: Restrict)
  userUuid   String
  userByUuid AuthUser               @relation("TaskActivityUserByUuid", fields: [userUuid], references: [uuid], onDelete: Restrict)
  actionType TaskActivityActionType
  field      TaskActivityField?
  oldValue   String?
  newValue   String?
  createdAt  DateTime               @default(now())

  @@index([taskId, createdAt])
  @@index([taskUuid, createdAt])
  @@index([userId, createdAt])
  @@index([userUuid, createdAt])
}

model OutboundEmail {
  id        Int      @id @default(autoincrement())
  to        String
  subject   String
  html      String
  text      String
  kind      String
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
}

model Document {
  id                String          @id @default(uuid())
  taskId            String?         @map("task_id")
  task              Task?           @relation("DocumentTaskByUuid", fields: [taskId], references: [uuid], onDelete: SetNull)
  documentFolderId  String?         @map("document_folder_id")
  documentFolder    DocumentFolder? @relation("DocumentFolderDocumentsById", fields: [documentFolderId], references: [id], onDelete: SetNull)
  name              String
  originalFilename  String          @map("original_filename")
  storageProvider   String          @default("local") @map("storage_provider")
  storageKey        String          @unique @map("storage_key")
  mimeType          String          @map("mime_type")
  fileSizeBytes     Int             @map("file_size_bytes")
  uploadedByUserId  String          @map("uploaded_by_user_id")
  uploadedByUser    AuthUser        @relation("DocumentUploaderByUuid", fields: [uploadedByUserId], references: [uuid], onDelete: Restrict)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  @@index([taskId], map: "documents_task_id_idx")
  @@index([documentFolderId], map: "documents_document_folder_id_idx")
  @@index([deletedAt], map: "documents_deleted_at_idx")
  @@map("documents")
}

model DocumentFolder {
  id              String           @id @default(uuid())
  projectId       String           @map("project_id")
  project         Project          @relation("DocumentFolderProjectByUuid", fields: [projectId], references: [uuid], onDelete: Cascade)
  parentFolderId  String?          @map("parent_folder_id")
  parentFolder    DocumentFolder?  @relation("DocumentFolderHierarchy", fields: [parentFolderId], references: [id], onDelete: SetNull)
  childFolders    DocumentFolder[] @relation("DocumentFolderHierarchy")
  name            String
  description     String?
  sortOrder       Int?             @map("sort_order")
  isSystem        Boolean          @default(false) @map("is_system")
  createdByUserId String?          @map("created_by_user_id")
  createdByUser   AuthUser?        @relation("DocumentFolderCreatorByUuid", fields: [createdByUserId], references: [uuid], onDelete: SetNull)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  archivedAt      DateTime?        @map("archived_at")
  documents       Document[]       @relation("DocumentFolderDocumentsById")

  @@unique([projectId, parentFolderId, name], map: "document_folders_project_parent_name_key")
  @@index([projectId], map: "document_folders_project_id_idx")
  @@index([parentFolderId], map: "document_folders_parent_folder_id_idx")
  @@index([archivedAt], map: "document_folders_archived_at_idx")
  @@map("document_folders")
}
